{
  "name": "suomsiang-videocut",
  "version": "1.0.0",
  "description": "สุ่มเสียง VIDEOCUT — โปรแกรมตัดต่อวิดีโอ (Native FFmpeg)",
  "main": "main.js",
  "author": "SUOMSIANG",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "SUOMSIANG_DEV=1 electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0"
  },
  "build": {
    "appId": "com.suomsiang.videocut",
    "productName": "SUOMSIANG VIDEOCUT",
    "files": [
      "main.js",
      "preload.js",
      "app/**/*",
      "build/icon.*"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png",
      "category": "public.app-category.video"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "category": "AudioVideo"
    }
  }
}
